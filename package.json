    "@girs/gnome-shell": "^48.0.0",
    "@tsconfig/recommended": "^1.0.10",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "markdownlint-cli2": "^0.17.0",
    "typescript": "^5.8.3"
  }
